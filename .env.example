# Скопируй в .env (локально) или впиши в переменные окружения хостинга.
# НИКОГДА не публикуй BOT_TOKEN и не коммить .env в git.

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456:ABC-DEF...

# Канал, куда постим. @username (бот должен быть админом) или числовой -100xxxxxxxxxx
CHANNEL_ID=@your_channel

# Данные товара для CTA
OZON_ARTIKUL=1931921872
OZON_LINK=https://www.ozon.ru/product/your-product
TG_CHANNEL_LINK=https://t.me/your_channel

# Расписание постинга: одно или несколько времён через запятую
# "10:00" = 1 раз в день; "10:00,18:00" = 2 раза в день
POST_TIMES=10:00
TZ=Europe/Moscow

# CTA на Ozon добавляется к каждому N-му посту
CTA_EVERY=4
